variables {
  variable "EnvironmentName" {
    type  = "String"
    value = "Dev"

    scope = {
      environments = [
        "Environments-1", # match your environment IDs
      ]
    }
  }

  variable "App.BaseUrl" {
    type  = "String"
    value = "https://example.local"

    scope = {
      environments = [
        "Environments-1",
      ]
    }
  }

  variable "App.ApiKey" {
    type  = "Sensitive"
    value = "PLEASE-OVERRIDE-IN-UI-OR-LIBRARY-SET"
  }
}
